# Copy to ~/.dbt/profiles.yml or set DBT_PROFILES_DIR to this directory.
morgan:
  target: dev
  outputs:
    dev:
      type: clickhouse
      schema: morgan
      host: "{{ env_var('CLICKHOUSE_HOST', 'localhost') }}"
      port: "{{ env_var('CLICKHOUSE_PORT', '8123') | as_number }}"
      user: "{{ env_var('CLICKHOUSE_USER', 'default') }}"
      password: "{{ env_var('CLICKHOUSE_PASSWORD', '') }}"
      secure: "{{ env_var('CLICKHOUSE_SECURE', 'false') | as_bool }}"
      verify: "{{ env_var('CLICKHOUSE_VERIFY', 'false') | as_bool }}"
      threads: 4
